# Скопируйте в файл `.env` в этой же папке и подставьте значения.
# Приложение подхватывает `.env` автоматически (python-dotenv), см. начало app_objects.py.

# --- Интеграция с «Диспетчер задач» (Post /api/integration/from-taskmgr/object) ---
# Один и тот же секрет, что OBJECT_ACCOUNTING_API_KEY на стороне диспетчера:
INTEGRATION_API_KEY=
# Числовой id пользователя в таблице users этой БД — владелец создаваемых объектов:
INTEGRATION_USER_ID=

# Опционально:
# PORT=5000
# DATABASE_URL=postgresql://...
# SECRET_KEY=
