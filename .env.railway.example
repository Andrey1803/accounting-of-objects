# Copy to .env.railway (gitignored). Use ONE primary line for CLI deploy:
#
# Recommended (account token — when creating token, leave "Workspace" EMPTY):
RAILWAY_API_TOKEN=
#
# Alternative: project token from Project Settings (then use RAILWAY_TOKEN only, not both):
# RAILWAY_TOKEN=
#
# Опционально — для scripts/utils/sync_sqlite_to_postgres.py с домашнего ПК:
# DATABASE_PUBLIC_URL=   (из Railway CLI: railway variable list -s <Postgres> -e production --json)
# или DATABASE_URL= с тем же публичным хостом *.proxy.rlwy.net
